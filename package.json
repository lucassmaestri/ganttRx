{
  "name": "gantt-rx",
  "version": "1.0.0",
  "description": "A powerful React + TypeScript Gantt chart library with histogram, resource allocation, critical path and auto-scheduling",
  "author": "GanttRx Contributors",
  "license": "MIT",
  "keywords": [
    "gantt",
    "react",
    "typescript",
    "project-management",
    "scheduler",
    "timeline",
    "histogram",
    "critical-path",
    "resource-allocation",
    "canvas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lucassmaestri/ganttRx.git"
  },
  "homepage": "https://github.com/lucassmaestri/ganttRx#readme",
  "bugs": {
    "url": "https://github.com/lucassmaestri/ganttRx/issues"
  },
  "type": "module",
  "main": "./dist/gantt-rx.cjs.js",
  "module": "./dist/gantt-rx.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/gantt-rx.es.js",
      "require": "./dist/gantt-rx.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --mode lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
